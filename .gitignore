# ── Go ───────────────────────────────────────────────────────────────────────
bin/
*.log

# ── Node / VitePress docs ────────────────────────────────────────────────────
node_modules/
/dist
docs/.vitepress/cache/
docs/.vitepress/dist/

# ── Android ──────────────────────────────────────────────────────────────────
# Gradle build outputs
android/.gradle/
android/build/
android/app/build/

# Android Studio / IntelliJ
*.iml
.idea/
.idea/**

# Local machine-specific SDK paths (never commit this)
android/local.properties

# Keystore files (signing keys — keep out of version control)
*.jks
*.keystore

# Generated APK / AAB artefacts (use CI releases instead)
*.apk
*.aab

# Compiled Go binary bundled in assets (regenerated by build script)
android/app/src/main/assets/phoenix-client

# ── OS / Editor ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
.vscode/
*.swp
*.swo
